# ─── Vercel Postgres ──────────────────────────────────────────────────────────
# These are auto-populated when you add a Postgres database in the Vercel dashboard
# (Storage → Create Database → Postgres). Copy them to your local .env.local for dev.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
# Password for the /admin page. Set a strong value in your Vercel environment variables.
ADMIN_SECRET="change-me-to-a-strong-password"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at https://resend.com, create an API key, and add it here.
# Capacity alert emails (80%, 90%, 100%) are sent to the admin contact email.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# The "From" address — must be a verified domain in your Resend account.
# During development you can use: onboarding@resend.dev (only delivers to your Resend account email)
RESEND_FROM="Dunany Concert Series <noreply@dunany.ca>"
