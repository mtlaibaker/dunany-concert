generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url = env("DATABASE_URL")
}

model Registration {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  email       String?
  phone       String?
  memberCount Int      @default(0)
  guestCount  Int      @default(0)
  isMember    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([eventId])
}

model SiteConfig {
  id           Int    @id @default(1)
  contactEmail String @default("Dan_Leblanc13@hotmail.com")
}

model EventConfig {
  eventId     String   @id
  artist      String?
  isoDate     String?
  genre       String?
  genreFr     String?
  tbd         Boolean?
  maxCapacity Int?
  updatedAt   DateTime @updatedAt
}
