generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url = env("DATABASE_URL")
}

model Registration {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  email     String?
  phone     String?
  isMember  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([eventId])
}
